# Copy this file to .env and fill in your keys.
# Load it before running:
#   Linux/Mac:  source .env
#   Windows:    dotenv .env   or set vars manually in PowerShell

# Optional — risk-free rate (3-month T-bill, 10-year Treasury).
# Used in WACC and Sharpe/Sortino calculations.
# Falls back to 5% when absent. Free key at:
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Optional — Nasdaq Data Link key for Sharadar point-in-time data.
# Only needed for backtesting (stockgrader.backtest module).
# Requires a Sharadar Core US Equities subscription (~$50/mo).
# https://data.nasdaq.com/
NASDAQ_DATA_LINK_API_KEY=your_nasdaq_data_link_key_here

# Optional — override the default config.yaml location
# STOCKGRADER_CONFIG=/path/to/your/config.yaml
