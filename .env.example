# Copy this file to .env and fill in your keys.
# Load it before running:
#   Linux/Mac:  source .env
#   Windows PS: Get-Content .env | ForEach-Object { $k,$v = $_ -split '=',2; [System.Environment]::SetEnvironmentVariable($k,$v) }
#   Or per-run: python -m dotenv run python analyze.py AAPL

# ── Optional: FMP deep-dive analysis ──────────────────────────────────────────
# Enables --deep flag on analyze.py: richer fundamentals (quarterly, TTM ratios),
# GICS peer list, and peer-relative percentile scoring.
# Free tier: 250 requests/day — sufficient for ~25 stocks per day with peer metrics.
# Get a free key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# ── Optional: FRED risk-free rates ────────────────────────────────────────────
# Improves WACC and Sharpe/Sortino accuracy with live T-bill / Treasury rates.
# Falls back to 5% when absent. Free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Optional: Sharadar PIT data (backtesting only) ────────────────────────────
# Only needed for stockgrader.backtest module. Requires Core US Equities subscription.
# https://data.nasdaq.com/
NASDAQ_DATA_LINK_API_KEY=your_nasdaq_data_link_key_here

# ── Optional: override config.yaml location ───────────────────────────────────
# STOCKGRADER_CONFIG=/path/to/your/config.yaml
