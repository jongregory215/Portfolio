# Copy this file to .env and fill in your API keys.
# Load it before running: source .env  (Linux/Mac)  or  dotenv .env (Windows)

# Required for fundamental data (income statement, balance sheet, cash flow,
# key metrics, peer list, full universe). Free tier: 250 req/day.
# Get a key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# Required for risk-free rate (3-month T-bill, 10-year Treasury).
# Used in WACC calculation and Sharpe/Sortino ratios.
# Free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Optional: Nasdaq Data Link key for Sharadar point-in-time data (backtesting only).
# Free tier does not include Sharadar; requires Core US Equities subscription.
# https://data.nasdaq.com/
NASDAQ_DATA_LINK_API_KEY=your_nasdaq_data_link_key_here

# Optional: override the default config.yaml location
# STOCKGRADER_CONFIG=/path/to/your/config.yaml
